## Inline-style React mapping (canvas prototypes)

Inline-style canvas prototypes can't read CSS variables from a separate sheet via `style={{ color: 'var(--ml-fg)' }}` reliably across all environments — better to mirror the tokens in a single typed `T` object at the top of the file.

```tsx
const T = {
  // surfaces
  bg: "#FFFFFF",
  bgSubtle: "#F6F6F6",
  bgMuted: "#EEEEEE",
  bgInverse: "#000000",
  // text
  fg: "#000000",
  fgMuted: "rgba(0,0,0,0.6)",
  fgSubtle: "rgba(0,0,0,0.32)",
  fgInverse: "#FFFFFF",
  // brand + semantic
  accent: "#00E5C4",
  accentFg: "#000000",
  danger: "#FF5E57",
  warning: "#FFDD59",
  success: "#00CC88",
  // borders
  border: "#E2E2E2",
  borderStrong: "#000000",
  // radii
  rXs: 4, rSm: 8, rMd: 14, rLg: 20, rXl: 24, r2xl: 40, rPill: 9999,
  // shadows
  shadowSm: "0 1px 2px rgba(0,0,0,0.06)",
  shadowMd: "0 6px 16px rgba(0,0,0,0.08)",
  shadowLg: "0 16px 32px rgba(0,0,0,0.10)",
} as const;

const FONT_FAMILY =
  '"Baton Turbo", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif';

const TYPE = {
  displaySm: { font: "700 36px/44px " + FONT_FAMILY, letterSpacing: "-0.030em" },
  headline:  { font: "500 28px/36px " + FONT_FAMILY, letterSpacing: "-0.030em" },
  titleLg:   { font: "500 24px/32px " + FONT_FAMILY, letterSpacing: "-0.030em" },
  titleMd:   { font: "500 20px/28px " + FONT_FAMILY, letterSpacing: "-0.030em" },
  bodyLg:    { font: "400 16px/24px " + FONT_FAMILY, letterSpacing: "-0.020em" },
  bodyMd:    { font: "400 14px/20px " + FONT_FAMILY, letterSpacing: "-0.020em" },
  labelMd:   { font: "500 14px/20px " + FONT_FAMILY, letterSpacing: "-0.010em" },
} as const;
```

