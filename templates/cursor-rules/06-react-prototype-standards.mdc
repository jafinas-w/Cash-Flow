## Phone Frame Wrapper

Every screen-level prototype must include the phone frame wrapper per `05-design-system.mdc` specs:

```tsx
const PhoneFrame = ({ children }: { children: React.ReactNode }) => (
  <div style={{
    width: [FRAME_WIDTH],
    minHeight: [FRAME_HEIGHT],
    backgroundColor: 'var(--bg-primary)',
    borderRadius: 44,
    overflow: 'hidden',
    boxShadow: 'var(--shadow-lg)',
    fontFamily: 'var(--font-family)',
    position: 'relative',
  }}>
    {/* Status bar */}
    <div style={{
      height: [STATUS_BAR_HEIGHT],
      backgroundColor: 'var(--bg-secondary)',
      display: 'flex',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: '0 var(--space-20)',
    }}>
      <span style={{ fontSize: 15, fontWeight: 600 }}>[TIME]</span>
      {/* Signal / battery icons */}
    </div>

    {/* Scrollable content */}
    <div style={{ flex: 1, overflowY: 'auto', paddingBottom: [BOTTOM_NAV_HEIGHT] }}>
      {children}
    </div>
  </div>
);
```

