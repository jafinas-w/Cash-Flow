## TypeScript Standards

```ts
// ✅ Explicit types — no `any`
interface Transaction {
  id: string;
  merchant: string;
  amount: number;   // Always in cents or consistent unit — document which
  date: Date;
  category: TransactionCategory;
}

type TransactionCategory = '[CATEGORY_1]' | '[CATEGORY_2]' | '[CATEGORY_3]';

// ❌ Never
const handler = (data: any) => { ... };
```

